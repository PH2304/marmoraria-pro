<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.com.marmoraria.controller.CalculadoraController"
      spacing="15"
      padding="20">

    <!-- SELEÇÃO -->
    <HBox spacing="10">
        <ComboBox fx:id="cbMaterial" promptText="Material" prefWidth="220"/>
        <ComboBox fx:id="cbServico" promptText="Serviço" prefWidth="220"/>
    </HBox>

    <!-- DIMENSÕES -->
    <HBox spacing="10">
        <TextField fx:id="txtLargura" promptText="Largura (mm)" prefWidth="120"/>
        <TextField fx:id="txtComprimento" promptText="Comprimento (mm)" prefWidth="150"/>
        <TextField fx:id="txtQuantidade" promptText="Qtd" prefWidth="80"/>
    </HBox>

    <!-- AÇÕES -->
    <HBox spacing="10">
        <Button text="Adicionar ao Orçamento"
                onAction="#adicionarItem"
                prefWidth="200"/>
    </HBox>

    <!-- TABLE VIEW DO ORÇAMENTO -->
    <Label text="Itens do Orçamento"
           style="-fx-font-weight: bold; -fx-font-size: 14px"/>

    <TableView fx:id="tabelaOrcamento" prefHeight="250">
        <columns>
            <TableColumn fx:id="colMaterial" text="Material" prefWidth="150"/>
            <TableColumn fx:id="colServico" text="Serviço" prefWidth="120"/>
            <TableColumn fx:id="colDimensoes" text="Dimensões (mm)" prefWidth="140"/>
            <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="60"/>
            <TableColumn fx:id="colArea" text="Área (m²)" prefWidth="100"/>
            <TableColumn fx:id="colTotal" text="Total (R$)" prefWidth="100"/>
        </columns>
    </TableView>

    <!-- TOTAL -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label text="Total do Orçamento:" style="-fx-font-weight: bold"/>
        <Label fx:id="lblTotalOrcamento"
               text="R$ 0,00"
               style="-fx-font-weight: bold; -fx-font-size: 16px"/>
    </HBox>

    <Label fx:id="lblTotalGeral"
           text="TOTAL: R$ 0,00"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>

    <VBox spacing="8">

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Subtotal:"/>
            <Label fx:id="lblSubtotal" text="R$ 0,00"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Desconto (%):"/>
            <TextField fx:id="txtDesconto" prefWidth="80"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Total com Desconto:"/>
            <Label fx:id="lblTotalComDesconto" text="R$ 0,00"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Margem de Lucro (%):"/>
            <TextField fx:id="txtMargem" prefWidth="80"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="TOTAL FINAL:" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblTotalFinal"
                   text="R$ 0,00"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
        </HBox>
    </VBox>

    <Button text="Gerar PDF"
            onAction="#gerarPDF"
            style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;"
            prefWidth="150"/>
</VBox>